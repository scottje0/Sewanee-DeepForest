## IoU and mAP Statistics

# For IoU, first run the model to predict each image. At the end of each cell of code, add:

species_predictions.to_csv("df info/evaluation/FILENAME.csv", index=False)

# If it isn't already installed, run
pip install pandas scipy numpy

# Label the true bounding box predictions in Label Studio for each image and import them into the same
# folder as the model predictions. 
## DO NOT convert these files to CSV, leave them as XML. 

# Then, run this to get the IoU statistic.
import os
import glob
import xml.etree.ElementTree as ET
import pandas as pd
import numpy as np
from scipy.optimize import linear_sum_assignment

# CHANGE THIS to the folder where your ground truth .xml files
# and prediction .csv files both live
UPLOAD_DIR = r"C:\Users\USERNAME\df info\evaluation\annotations"

def parse_voc_xml(xml_path):
    tree = ET.parse(xml_path)
    root = tree.getroot()
    boxes = []
    for obj in root.findall("object"):
        bnd = obj.find("bndbox")
        xmin = float(bnd.find("xmin").text)
        ymin = float(bnd.find("ymin").text)
        xmax = float(bnd.find("xmax").text)
        ymax = float(bnd.find("ymax").text)
        boxes.append([xmin, ymin, xmax, ymax])
    return boxes
def iou(boxA, boxB):
    xA = max(boxA[0], boxB[0])
    yA = max(boxA[1], boxB[1])
    xB = min(boxA[2], boxB[2])
    yB = min(boxA[3], boxB[3])
    inter_w = max(0, xB - xA)
    inter_h = max(0, yB - yA)
    inter_area = inter_w * inter_h
    areaA = (boxA[2] - boxA[0]) * (boxA[3] - boxA[1])
    areaB = (boxB[2] - boxB[0]) * (boxB[3] - boxB[1])
    union = areaA + areaB - inter_area
    if union <= 0:
        return 0.0
    return inter_area / union
xml_files = glob.glob(os.path.join(UPLOAD_DIR, "*.xml"))
csv_files = glob.glob(os.path.join(UPLOAD_DIR, "*.csv"))
def image_key_from_xml(fname):
    base = os.path.basename(fname).replace(".xml", "")
    parts = base.split("-", 1)
    return parts[-1] if len(parts) > 1 else parts[0]
def image_key_from_csv(fname):
    df = pd.read_csv(fname)
    if len(df) == 0:
        return None
    img_path = df["image_path"].iloc[0]
    return os.path.splitext(os.path.basename(img_path))[0]
gt_map = {image_key_from_xml(f): f for f in xml_files}
pred_map = {}
for f in csv_files:
    key = image_key_from_csv(f)
    pred_map[key] = f
all_matches = []  # per-box match records
per_image_summary = []
for key in sorted(gt_map.keys()):
    if key not in pred_map:
        print(f"WARNING: no prediction file found for {key}")
        continue
    gt_boxes = parse_voc_xml(gt_map[key])
    pred_df = pd.read_csv(pred_map[key])
    pred_boxes = pred_df[["xmin", "ymin", "xmax", "ymax"]].values.tolist()
    pred_labels = pred_df["label"].tolist() if "label" in pred_df.columns else [None] * len(pred_boxes)
    pred_scores = pred_df["score"].tolist() if "score" in pred_df.columns else [None] * len(pred_boxes)
    n_gt = len(gt_boxes)
    n_pred = len(pred_boxes)
    # Build IoU cost matrix (gt rows x pred cols)
    if n_gt > 0 and n_pred > 0:
        iou_matrix = np.zeros((n_gt, n_pred))
        for i, gb in enumerate(gt_boxes):
            for j, pb in enumerate(pred_boxes):
                iou_matrix[i, j] = iou(gb, pb)
        # Hungarian algorithm to find optimal one-to-one assignment
        # maximize total IoU -> minimize negative IoU
        row_ind, col_ind = linear_sum_assignment(-iou_matrix)
    else:
        row_ind, col_ind = np.array([], dtype=int), np.array([], dtype=int)
        iou_matrix = np.zeros((n_gt, n_pred))
    matched_gt = set()
    matched_pred = set()
    for r, c in zip(row_ind, col_ind):
        score = iou_matrix[r, c]
        matched_gt.add(r)
        matched_pred.add(c)
        all_matches.append({
            "image": key,
            "gt_index": r,
            "gt_box": gt_boxes[r],
            "pred_index": c,
            "pred_box": pred_boxes[c],
            "pred_label": pred_labels[c],
            "pred_score": pred_scores[c],
            "iou": round(score, 4),
            "matched": score > 0  # 0 IoU means Hungarian paired them but they don't overlap at all
        })
    # Any GT boxes left unmatched (more GT than pred, or IoU was 0 and got filtered) get IoU = 0
    for i in range(n_gt):
        if i not in matched_gt:
            all_matches.append({
                "image": key,
                "gt_index": i,
                "gt_box": gt_boxes[i],
                "pred_index": None,
                "pred_box": None,
                "pred_label": None,
                "pred_score": None,
                "iou": 0.0,
                "matched": False
            })
    # unmatched predictions = false positives (extra boxes with no GT partner)
    n_unmatched_preds = n_pred - len(matched_pred)
    image_ious = [m["iou"] for m in all_matches if m["image"] == key]
    per_image_summary.append({
        "image": key,
        "n_ground_truth_boxes": n_gt,
        "n_predicted_boxes": n_pred,
        "n_unmatched_predictions_fp": n_unmatched_preds,
        "mean_iou": round(np.mean(image_ious), 4) if image_ious else 0.0
    })
# Save detailed per-box results
detail_df = pd.DataFrame(all_matches)
detail_df.to_csv("iou_per_box_detail.csv", index=False)
# Save per-image summary
summary_df = pd.DataFrame(per_image_summary)
summary_df.to_csv("iou_per_image_summary.csv", index=False)
overall_mean_iou = detail_df["iou"].mean()
print("\n=== Per-Image Summary ===")
print(summary_df.to_string(index=False))
print(f"\nOverall mean IoU across all {len(detail_df)} ground truth boxes: {overall_mean_iou:.4f}")

