# Import packages 
import warnings
warnings.filterwarnings('ignore')
import matplotlib.pyplot as plt
import matplotlib.patches as patches
from PIL import Image
import numpy as np
import pandas as pd
from deepforest import main as deepforest_main
from deepforest import main
import rasterio
import os

# Training the model

# Import the pre-trained object detection model

m = main.deepforest()
m.load_model(model_name="weecology/deepforest-tree", revision="main")
print("Model loaded successfully")

# Point to your annotation CSV and image directory

m.config.train.csv_file = "FILENAME.csv"    
m.config.train.root_dir = "df info/images/" 
m.config.train.epochs = 5          # 5-10 is usually enough
m.config.train.fast_dev_run = False
m.create_trainer()
m.trainer.fit(m)

# Save the model

m.save_model("dftreedetection1.pt")

# To load the model later:

m = main.deepforest.load_from_checkpoint("dftreedetection1.pt")

# Run the model on an image and plot the results:

IMAGE_PATH = "df info/images/FILENAME.png"
boxes = model.predict_tile(
    path=IMAGE_PATH,
    patch_size=1500,    # we found that a patch size 800-2000 works best, adjust as necessary
    patch_overlap=0.25,
    iou_threshold=0.15
)
print(f"Trees detected: {len(boxes)}")
print(boxes.head(10))

def plot_detections(image_path, boxes_df, figsize=(14, 10), box_color='lime', linewidth=1.5):
    img = Image.open(image_path).convert("RGB")
    fig, ax = plt.subplots(1, 1, figsize=figsize)
    ax.imshow(np.array(img))
    ax.axis('off')
    for _, row in boxes_df.iterrows():
        x, y = row['xmin'], row['ymin']
        w = row['xmax'] - row['xmin']
        h = row['ymax'] - row['ymin']
        rect = patches.Rectangle((x, y), w, h, linewidth=linewidth, edgecolor=box_color, facecolor='none')
        ax.add_patch(rect)
    ax.set_title(f"DeepForest Tree Detection  |  {len(boxes_df)} trees found", fontsize=13)
    plt.tight_layout()
    plt.show()

plot_detections(IMAGE_PATH, boxes)
